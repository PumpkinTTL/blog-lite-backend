# Copy this file to .env for local development.
# Do not commit real secrets or machine-specific values.

# Runtime environment: development, test, or production.
NODE_ENV=development

# NestJS HTTP server port.
PORT=5100

# Allowed browser origins for CORS. Use comma-separated URLs for multiple dev apps.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# MySQL database connection.
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=blog-lite

# Enable TypeORM synchronize only in local development.
DB_SYNCHRONIZE=true

# Runtime log level: debug, info, warn, error.
LOG_LEVEL=debug

# Auth Center (统一鉴权服务)
AUTH_CENTER_URL=http://localhost:5200
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
