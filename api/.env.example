# Copy this file to .env for local development.
# Do not commit real secrets or machine-specific values.

# Runtime environment: development, test, or production.
NODE_ENV=development

# NestJS HTTP server port.
PORT=5100

# Allowed browser origins for CORS. Use comma-separated URLs for multiple dev apps.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# MySQL database connection.
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=blog-lite

# Enable TypeORM synchronize only in local development.
DB_SYNCHRONIZE=true

# Runtime log level: debug, info, warn, error.
LOG_LEVEL=debug

# Auth Center (统一鉴权服务)
AUTH_CENTER_URL=http://localhost:5200
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=

# AI / LLM (OpenAI compatible). Used by AiModule: subtitle/summary/slug generation.
AI_BASE_URL=https://9router.bitlesu.com/v1
AI_API_KEY=
AI_DEFAULT_MODEL=cmc/deepseek/deepseek-v4-flash

# Tavily (联网搜索,写作助手 web_search 工具用). Free tier 1000 次/月.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
